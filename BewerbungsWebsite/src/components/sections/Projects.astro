---
import { existsSync } from "node:fs";
import { join } from "node:path";
import Section from "../ui/Section.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Card from "../ui/Card.astro";
import Icon from "../ui/Icon.astro";
import { projects as defaultProjects, type Project } from "../../data/projects";

interface Props {
  items?: Project[];
}

const { items = defaultProjects } = Astro.props;

const withImage = items.map((p) => ({
  ...p,
  hasImage: existsSync(join(process.cwd(), "public", p.image)),
}));
---

<Section id="projekte" surface labelledby="projekte-title">
  <div class="max-w-2xl" data-reveal>
    <Eyebrow>Projekte</Eyebrow>
    <h2
      id="projekte-title"
      class="mt-4 font-display text-3xl font-medium leading-tight tracking-tight text-ink sm:text-4xl"
    >
      Ausgewählte Projekte.
    </h2>
    <p class="mt-4 text-sm text-muted">Details folgen in Kürze.</p>
  </div>

  <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      withImage.map((p, i) => (
        <Card href={p.href} padded={false} class="overflow-hidden" data-reveal style={`--reveal-delay:${i * 60}ms`}>
          <div class="flex aspect-[16/10] items-center justify-center bg-[#eceae5] text-[#b9b6ae]">
            {p.hasImage ? (
              <img src={p.image} alt={p.title} class="h-full w-full object-cover" />
            ) : (
              <Icon name="image" class="h-8 w-8" />
            )}
          </div>
          <div class="p-6">
            <h3 class="text-base font-medium text-ink">{p.title}</h3>
            <p class="mt-1.5 text-sm text-muted">In Kürze mehr</p>
          </div>
        </Card>
      ))
    }
  </div>
</Section>
