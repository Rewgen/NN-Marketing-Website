---
import Section from "../ui/Section.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import ComingSoon from "../ui/ComingSoon.astro";
---

<Section id="workstyle" labelledby="workstyle-title">
  <div class="max-w-2xl" data-reveal>
    <Eyebrow>Meine Arbeitsweise</Eyebrow>
    <h2
      id="workstyle-title"
      class="mt-4 font-display text-3xl font-medium leading-tight tracking-tight text-ink sm:text-4xl"
    >
      Wie ich an Projekte herangehe.
    </h2>
  </div>

  <div class="mt-10">
    <ComingSoon />
  </div>
</Section>
