---
import Section from "../ui/Section.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Button from "../ui/Button.astro";
import Modal from "../ui/Modal.astro";
import Icon from "../ui/Icon.astro";
import { resume as defaultResume, cvDownloadHref, type ResumeEntry } from "../../data/resume";

interface Props {
  items?: ResumeEntry[];
}

const { items = defaultResume } = Astro.props;

const focus = [
  "Projektmanagement",
  "Kundenbetreuung & Bestandskundenpflege",
  "Prozessoptimierung",
  "Stakeholder-Kommunikation",
  "Digitalisierung & KI",
];

const categoryLabels: Record<ResumeEntry["category"], string> = {
  work: "Berufserfahrung",
  training: "Weiterbildung",
  education: "Ausbildung",
};

const grouped = (["work", "training", "education"] as const).map((cat) => ({
  label: categoryLabels[cat],
  entries: items.filter((e) => e.category === cat),
})).filter((g) => g.entries.length > 0);

// For the preview timeline: show work entries only, max 3
const previewItems = items.filter((e) => e.category === "work").slice(0, 3);
---

<Section id="resume" labelledby="resume-title">
  <div class="max-w-2xl" data-reveal>
    <Eyebrow>Lebenslauf</Eyebrow>
    <h2
      id="resume-title"
      class="mt-4 font-display text-3xl font-medium leading-tight tracking-tight text-ink sm:text-4xl"
    >
      Mein Weg in Kürze.
    </h2>
  </div>

  <ol class="mt-10 max-w-xl">
    {
      previewItems.map((e, i) => (
        <li
          class="relative border-l border-line pb-9 pl-7 last:border-l-transparent last:pb-0"
          data-reveal
          style={`--reveal-delay:${i * 60}ms`}
        >
          <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-accent" />
          <p class="text-xs font-medium text-accent">{e.period}</p>
          <h3 class="mt-1 text-base font-medium text-ink">{e.role}</h3>
          {e.org && <p class="mt-0.5 text-xs font-medium text-accent-deep">{e.org}</p>}
          {e.description && <p class="mt-1 text-sm leading-relaxed text-muted">{e.description}</p>}
        </li>
      ))
    }
  </ol>

  <Button type="button" variant="ghost" icon="arrow-right" class="mt-8" data-modal-open="cv-modal">
    Vollständigen Lebenslauf ansehen
  </Button>
</Section>

<Modal id="cv-modal" size="full" labelledby="cv-modal-title">
  <div class="mx-auto flex max-w-2xl flex-wrap items-end justify-between gap-4">
    <div>
      <Eyebrow>Lebenslauf</Eyebrow>
      <h2 id="cv-modal-title" class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink">
        Mein Werdegang.
      </h2>
    </div>
    <a
      href={cvDownloadHref}
      class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white transition hover:bg-accent-deep"
    >
      <Icon name="download" class="h-4 w-4" /> Als PDF herunterladen
    </a>
  </div>

  <div class="mt-12 mx-auto max-w-2xl space-y-16">
    {
      grouped.map((group, gi) => (
        <div class:list={[gi > 0 && "border-t border-line pt-12"]}>
          <h3 class="mb-8 font-display text-2xl font-semibold tracking-tight text-ink">
            {group.label}
          </h3>
          <ol>
            {group.entries.map((e) => (
              <li class="relative border-l border-line pb-10 pl-8 last:border-l-transparent last:pb-0">
                <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-accent" />
                <p class="text-sm font-medium text-accent">{e.period}</p>
                <h4 class="mt-1 font-display text-xl font-medium text-ink">{e.role}</h4>
                {e.org && (
                  <p class="mt-0.5 text-sm font-medium text-accent-deep">{e.org}</p>
                )}
                {e.achievements && e.achievements.length > 0 && (
                  <ul class="mt-3 space-y-1.5">
                    {e.achievements.map((a) => (
                      <li class="flex gap-2 text-sm leading-relaxed text-muted">
                        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent" />
                        <span>{a}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ol>
        </div>
      ))
    }
  </div>

  <div class="mt-12 mx-auto max-w-2xl border-t border-line pt-10">
    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent-deep">Schwerpunkte</p>
    <ul class="mt-3 flex flex-wrap gap-2">
      {
        focus.map((f) => (
          <li class="rounded-full bg-accent-tint px-3.5 py-1.5 text-sm font-medium text-accent-deep">
            {f}
          </li>
        ))
      }
    </ul>
  </div>
</Modal>
