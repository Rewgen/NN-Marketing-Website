---
import Section from "../ui/Section.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Button from "../ui/Button.astro";
import Modal from "../ui/Modal.astro";
import Icon from "../ui/Icon.astro";
import { resume as defaultResume, cvDownloadHref, type ResumeEntry } from "../../data/resume";

interface Props {
  items?: ResumeEntry[];
}

const { items = defaultResume } = Astro.props;

const focus = [
  "Projektmanagement",
  "Digitalisierung",
  "Prozessoptimierung",
  "KI & Automatisierung",
  "Kommunikation",
  "Organisation",
];
---

<Section id="resume" labelledby="resume-title">
  <div class="max-w-2xl" data-reveal>
    <Eyebrow>Lebenslauf</Eyebrow>
    <h2
      id="resume-title"
      class="mt-4 font-display text-3xl font-medium leading-tight tracking-tight text-ink sm:text-4xl"
    >
      Mein Weg in Kürze.
    </h2>
  </div>

  <ol class="mt-10 max-w-xl">
    {
      items.map((e, i) => (
        <li
          class="relative border-l border-line pb-9 pl-7 last:border-l-transparent last:pb-0"
          data-reveal
          style={`--reveal-delay:${i * 60}ms`}
        >
          <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-accent" />
          <p class="text-xs font-medium text-accent">{e.period}</p>
          <h3 class="mt-1 text-base font-medium text-ink">{e.role}</h3>
          <p class="mt-1 text-sm leading-relaxed text-muted">{e.description}</p>
        </li>
      ))
    }
  </ol>

  <Button type="button" variant="ghost" icon="arrow-right" class="mt-8" data-modal-open="cv-modal">
    Vollständigen Lebenslauf ansehen
  </Button>
</Section>

<Modal id="cv-modal" size="full" labelledby="cv-modal-title">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <Eyebrow>Lebenslauf</Eyebrow>
      <h2 id="cv-modal-title" class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink">
        Mein Werdegang.
      </h2>
    </div>
    <a
      href={cvDownloadHref}
      class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white transition hover:bg-accent-deep"
    >
      <Icon name="download" class="h-4 w-4" /> Als PDF herunterladen
    </a>
  </div>

  <div class="mt-8">
    <p class="text-xs font-medium uppercase tracking-[0.14em] text-accent-deep">Schwerpunkte</p>
    <ul class="mt-3 flex flex-wrap gap-2">
      {
        focus.map((f) => (
          <li class="rounded-full bg-accent-tint px-3.5 py-1.5 text-sm font-medium text-accent-deep">
            {f}
          </li>
        ))
      }
    </ul>
  </div>

  <ol class="mt-10 max-w-2xl">
    {
      items.map((e) => (
        <li class="relative border-l border-line pb-10 pl-8 last:border-l-transparent last:pb-0">
          <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-accent" />
          <p class="text-sm font-medium text-accent">{e.period}</p>
          <h3 class="mt-1 font-display text-xl font-medium text-ink">{e.role}</h3>
          <p class="mt-2 text-base leading-relaxed text-muted">{e.description}</p>
        </li>
      ))
    }
  </ol>
</Modal>
