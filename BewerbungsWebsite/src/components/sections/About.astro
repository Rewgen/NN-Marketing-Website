---
import Section from "../ui/Section.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Button from "../ui/Button.astro";
import Modal from "../ui/Modal.astro";
import Icon from "../ui/Icon.astro";

const values = [
  {
    icon: "target",
    title: "Disziplin",
    text: "... ist für mich der wichtigste Wert, weil sie die Kraft gibt, nach einem Rückschlag wieder aufzustehen und weiter seinen Beitrag zu leisten.",
  },
  {
    icon: "shield",
    title: "Loyalität",
    text: "... bedeutet für mich, wirklich hinter einer Sache zu stehen, egal ob Mensch, Unternehmen, persönliche Werte oder Versprechen.",
  },
  {
    icon: "heart",
    title: "Menschlichkeit",
    text: "... steht für mich dafür, den Menschen zu sehen, unabhängig von Herkunft oder Umständen, und ein ehrliches Interesse daran zu haben, dass es anderen gut geht.",
  },
];

const story = [
  "Wie viele stand ich anfangs vor der Herausforderung, mich für einen Weg zu entscheiden. Ich wusste nur, dass es mit Menschen zu tun haben sollte. Also habe ich im Einzelhandel angefangen. Dort habe ich gemerkt, dass ich ein besonderes Talent habe, mit Menschen zu interagieren, ihnen zuzuhören und zu verstehen, was sie brauchen.",
  "Danach kamen Stationen, die sich teilweise stark unterscheiden, manche geplant, manche eher zufällig entstanden. Vertrieb, Personalverantwortung, der Aufbau einer eigenen Selbstständigkeit. Jede davon hat mir etwas anderes beigebracht und mich für die kommenden Herausforderungen geformt.",
  "Am Ende war es aber eine Erkenntnis, die geblieben ist: Am meisten erfüllt es mich, Projekte zu organisieren, die Menschen wirklich weiterbringen. Mir reicht es nicht, nur ein Unternehmen erfolgreicher zu machen, ich will einen Beitrag leisten, der spürbar ist. Deshalb habe ich auch aus eigenem Antrieb ehrenamtliche Projekte gestartet und mich sozial eingebracht.",
  "Auf meinem Weg habe ich gelernt, dass Rückschläge kein Grund sind, aufzuhören, sondern der Anlass, sich neu aufzustellen. Diese Disziplin, mich nach jedem Rückschlag wieder aufzurichten und gestärkt weiterzumachen, gibt mir die Zuversicht, dass ich auch komplexe Projekte zuverlässig zum Ziel bringe.",
];
---

<Section id="about" labelledby="about-title">
  <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
    <div data-reveal>
      <Eyebrow>Über mich</Eyebrow>
      <h2
        id="about-title"
        class="mt-4 font-display text-3xl font-medium leading-tight tracking-tight text-ink sm:text-4xl"
      >
        Den Überblick behalten. Verantwortung übernehmen. Wirkung schaffen.
      </h2>
      <div class="mt-5 max-w-md space-y-4 text-base leading-relaxed text-muted">
        <p>
          Mein Weg war nicht geradlinig, aber ein roter Faden zieht sich durch: Projekte
          verwirklichen, Menschen weiterbringen. Das treibt mich an, seit ich weiß, wo ich hin
          will.
        </p>
      </div>
      <Button type="button" variant="ghost" icon="arrow-right" class="mt-6" data-modal-open="about-modal">
        Mehr erfahren
      </Button>
    </div>

    <ul class="flex flex-col gap-px overflow-hidden rounded-2xl border border-line bg-line">
      {
        values.map((v) => (
          <li class="bg-surface p-6" data-reveal>
            <div class="flex items-start gap-4">
              <Icon name={v.icon} class="mt-0.5 h-5 w-5 shrink-0 text-accent" />
              <div>
                <h3 class="font-display text-lg font-medium text-ink">{v.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted">{v.text}</p>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</Section>

<Modal id="about-modal" size="md" labelledby="about-modal-title">
  <Eyebrow>Über mich</Eyebrow>
  <h2 id="about-modal-title" class="mt-4 font-display text-3xl font-medium tracking-tight text-ink">
    Mehr über mich.
  </h2>
  <div class="mt-6 space-y-4 text-base leading-relaxed text-muted">
    {story.map((p) => <p>{p}</p>)}
  </div>
</Modal>
