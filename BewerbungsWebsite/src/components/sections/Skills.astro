---
import Section from "../ui/Section.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Icon from "../ui/Icon.astro";
import { skills as defaultSkills, workProcess, type Skill } from "../../data/skills";

interface Props {
  items?: Skill[];
}

const { items = defaultSkills } = Astro.props;
---

<Section id="skills" surface labelledby="skills-title">
  <div class="max-w-2xl" data-reveal>
    <Eyebrow>Wie ich arbeite</Eyebrow>
    <h2
      id="skills-title"
      class="mt-4 font-display text-3xl font-medium leading-tight tracking-tight text-ink sm:text-4xl"
    >
      Worin ich stark bin.
    </h2>
  </div>

  <div
    class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-x-0 lg:divide-x lg:divide-line"
  >
    {
      items.map((s) => (
        <div class="lg:px-6 lg:first:pl-0 lg:last:pr-0" data-reveal>
          <Icon name={s.icon} class="h-6 w-6 text-accent" />
          <h3 class="mt-4 text-sm font-medium text-ink">{s.title}</h3>
          <p class="mt-2 text-[13px] leading-relaxed text-muted">{s.text}</p>
        </div>
      ))
    }
  </div>

  <div class="mt-14 max-w-2xl" data-reveal>
    <p class="text-xs font-medium uppercase tracking-[0.14em] text-accent-deep">So gehe ich vor</p>
    <p class="mt-3 text-base leading-relaxed text-muted">{workProcess}</p>
  </div>
</Section>
