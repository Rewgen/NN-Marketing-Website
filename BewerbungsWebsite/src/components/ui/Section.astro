---
interface Props {
  id?: string;
  surface?: boolean;
  labelledby?: string;
  class?: string;
}

const { id, surface = false, labelledby, class: className = "" } = Astro.props;
---

<section
  id={id}
  aria-labelledby={labelledby}
  class:list={[
    "border-t border-line py-20 first:border-t-0 sm:py-28",
    surface ? "bg-surface" : "bg-canvas",
    className,
  ]}
>
  <div class="mx-auto w-full max-w-6xl px-6 sm:px-8">
    <slot />
  </div>
</section>
