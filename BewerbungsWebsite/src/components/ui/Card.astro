---
interface Props {
  href?: string;
  hover?: boolean;
  padded?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  hover = true,
  padded = true,
  class: className = "",
  ...rest
} = Astro.props;

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "block rounded-2xl border border-line bg-surface transition-all duration-300",
    padded && "p-6",
    hover && "hover:-translate-y-1 hover:shadow-[0_12px_40px_-16px_rgba(31,31,31,0.18)]",
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
