---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-canvas">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-10 sm:flex-row sm:items-center sm:justify-between sm:px-8"
  >
    <p class="font-display text-base text-ink">{site.name}</p>
    <p class="text-xs text-muted">© {year} {site.name}</p>
  </div>
</footer>
