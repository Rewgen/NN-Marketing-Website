---
import Hero from "./sections/Hero.astro";
import About from "./sections/About.astro";
import Skills from "./sections/Skills.astro";
import Projects from "./sections/Projects.astro";
import ResumePreview from "./sections/ResumePreview.astro";
import Engagement from "./sections/Engagement.astro";
import Contact from "./sections/Contact.astro";
import PasswordGate from "./PasswordGate.astro";

import type { Skill } from "../data/skills";
import type { Project } from "../data/projects";

/*
  Die wiederverwendbare "Wirbelsäule" der Website. Stellenspezifische Seiten
  (z. B. /firma-xy) rendern davor ihre eigenen Sektionen und können hier per
  Prop Inhalte ergänzen, ohne das Grundgerüst zu duplizieren.
*/
interface Props {
  skills?: Skill[];
  projects?: Project[];
}

const { skills, projects } = Astro.props;
---

<Hero />

{/* Alles unterhalb des Heros ist bis zur Passworteingabe ausgeblendet */}
<div id="gate-content" hidden>
  <About />
  <Skills items={skills} />
  <Projects items={projects} />
  <ResumePreview />
  <Engagement />
  <Contact />
</div>

<PasswordGate />
