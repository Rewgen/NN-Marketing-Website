---
import Modal from "./ui/Modal.astro";
import Eyebrow from "./ui/Eyebrow.astro";
import Icon from "./ui/Icon.astro";
import { site } from "../data/site";

/*
  Passwort-Gate für den unteren Teil der Seite: Der Inhalt in #gate-content
  bleibt ausgeblendet, bis das richtige Passwort eingegeben wurde. Geprüft wird
  gegen einen SHA-256-Hash, damit das Passwort nicht im Klartext im Quelltext
  steht. Hinweis: Das ist Sichtschutz, keine echte Zugriffskontrolle — die
  Inhalte liegen weiterhin im ausgelieferten HTML.
*/
const mailHref = `mailto:${site.contact.email}?subject=${encodeURIComponent(
  "Passwort für nilsnegwer.de"
)}`;
---

<Modal id="gate-modal" size="md" labelledby="gate-modal-title">
  <Eyebrow>Geschützter Bereich</Eyebrow>
  <h2 id="gate-modal-title" class="mt-4 font-display text-3xl font-medium tracking-tight text-ink">
    Lernen Sie mich näher kennen.
  </h2>
  <p class="mt-4 text-base leading-relaxed text-muted">
    Der vollständige Inhalt dieser Seite ist mit einem Passwort geschützt. Geben Sie das Passwort
    ein oder fragen Sie es unkompliziert per E-Mail an.
  </p>

  <form id="gate-form" class="mt-6" novalidate>
    <label for="gate-password" class="sr-only">Passwort</label>
    <input
      id="gate-password"
      type="password"
      name="password"
      placeholder="Passwort"
      autocomplete="off"
      required
      class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-base text-ink placeholder:text-muted"
    />
    <p id="gate-error" hidden class="mt-2 text-sm font-medium text-red-700">
      Das Passwort ist leider nicht korrekt.
    </p>
    <div class="mt-5 flex flex-wrap items-center gap-3">
      <button
        type="submit"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white transition hover:bg-accent-deep"
      >
        Freischalten
      </button>
      <a
        href={mailHref}
        class="inline-flex items-center gap-2 rounded-lg border border-line bg-surface px-5 py-3 text-sm font-medium text-ink transition hover:border-accent hover:text-accent-deep"
      >
        <Icon name="mail" class="h-4 w-4" /> Passwort anfragen
      </a>
    </div>
  </form>
</Modal>

<script>
  const KEY = "nn-gate-unlocked";
  const HASH = "94d52aba88bcbde543bf1b2f01b656901b9eae2ff3a20f4d2ad03407a32d422b";

  const gated = document.getElementById("gate-content");
  const dlg = document.getElementById("gate-modal") as HTMLDialogElement | null;
  const form = document.getElementById("gate-form") as HTMLFormElement | null;
  const input = document.getElementById("gate-password") as HTMLInputElement | null;
  const error = document.getElementById("gate-error");

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let pendingId: string | null = null;

  /*
    localStorage kann blockiert sein (z. B. Privatmodus) und wirft dann beim
    Zugriff — deshalb immer mit try/catch und In-Memory-Fallback für die Sitzung.
  */
  let unlockedInMemory = false;
  const unlocked = () => {
    try {
      if (localStorage.getItem(KEY) === "1") return true;
    } catch {
      /* Speicher nicht verfügbar */
    }
    return unlockedInMemory;
  };
  const persistUnlock = () => {
    unlockedInMemory = true;
    try {
      localStorage.setItem(KEY, "1");
    } catch {
      /* Speicher nicht verfügbar — Freischaltung gilt für diese Sitzung */
    }
  };
  const reveal = () => gated?.removeAttribute("hidden");

  if (unlocked()) reveal();

  const scrollToId = (id: string | null) => {
    const el = id ? document.getElementById(id) : null;
    el?.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" });
  };

  /*
    Klicks auf In-Page-Links in den gesperrten Bereich abfangen (Capture-Phase,
    läuft vor dem Smooth-Scroll-Handler im BaseLayout).
  */
  document.addEventListener(
    "click",
    (e) => {
      if (unlocked() || !gated || !dlg) return;
      const a = (e.target as Element).closest?.('a[href^="#"]');
      if (!a) return;
      const id = (a.getAttribute("href") ?? "").slice(1);
      const target = id ? document.getElementById(id) : null;
      if (!target || !gated.contains(target)) return;
      e.preventDefault();
      e.stopPropagation();

      // Mobiles Menü ggf. schließen, damit der Dialog frei steht
      const menu = document.getElementById("mobile-menu");
      const toggle = document.getElementById("nav-toggle");
      if (menu && !menu.hasAttribute("hidden")) {
        menu.setAttribute("hidden", "");
        toggle?.setAttribute("aria-expanded", "false");
      }

      pendingId = id;
      if (error) error.hidden = true;
      dlg.showModal();
      input?.focus();
    },
    true
  );

  async function sha256Hex(value: string): Promise<string> {
    const data = new TextEncoder().encode(value);
    const buf = await crypto.subtle.digest("SHA-256", data);
    return Array.from(new Uint8Array(buf))
      .map((b) => b.toString(16).padStart(2, "0"))
      .join("");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!input) return;
    let ok = false;
    try {
      ok = (await sha256Hex(input.value)) === HASH;
    } catch {
      ok = false;
    }
    if (ok) {
      persistUnlock();
      reveal();
      dlg?.close();
      input.value = "";
      scrollToId(pendingId ?? "about");
      pendingId = null;
    } else if (error) {
      error.hidden = false;
      input.select();
    }
  });
</script>
