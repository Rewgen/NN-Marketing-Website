---
import Modal from "./ui/Modal.astro";
import Eyebrow from "./ui/Eyebrow.astro";
import Icon from "./ui/Icon.astro";
import { site } from "../data/site";

/*
  Passwort-Gate für den unteren Teil der Seite: Der Inhalt in #gate-content
  bleibt ausgeblendet, bis das richtige Passwort eingegeben wurde. Geprüft wird
  gegen einen SHA-256-Hash, damit das Passwort nicht im Klartext im Quelltext
  steht. Hinweis: Das ist Sichtschutz, keine echte Zugriffskontrolle — die
  Inhalte liegen weiterhin im ausgelieferten HTML.
*/
const mailHref = `mailto:${site.contact.email}?subject=${encodeURIComponent(
  "Passwort für nilsnegwer.de"
)}`;
---

<Modal id="gate-modal" size="md" labelledby="gate-modal-title">
  <Eyebrow>Geschützter Bereich</Eyebrow>
  <h2 id="gate-modal-title" class="mt-4 font-display text-3xl font-medium tracking-tight text-ink">
    Lernen Sie mich näher kennen.
  </h2>
  <p class="mt-4 text-base leading-relaxed text-muted">
    Der vollständige Inhalt dieser Seite ist mit einem Passwort geschützt. Geben Sie das Passwort
    ein oder fragen Sie es unkompliziert per E-Mail an.
  </p>

  <form id="gate-form" class="mt-6" novalidate>
    <label for="gate-password" class="sr-only">Passwort</label>
    <input
      id="gate-password"
      type="password"
      name="password"
      placeholder="Passwort"
      autocomplete="off"
      required
      class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-base text-ink placeholder:text-muted"
    />
    <p id="gate-error" hidden class="mt-2 text-sm font-medium text-red-700">
      Das Passwort ist leider nicht korrekt.
    </p>
    <div class="mt-5 flex flex-wrap items-center gap-3">
      <button
        type="submit"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white transition hover:bg-accent-deep"
      >
        Freischalten
      </button>
      <a
        href={mailHref}
        class="inline-flex items-center gap-2 rounded-lg border border-line bg-surface px-5 py-3 text-sm font-medium text-ink transition hover:border-accent hover:text-accent-deep"
      >
        <Icon name="mail" class="h-4 w-4" /> Passwort anfragen
      </a>
    </div>
  </form>
</Modal>

<script>
  const KEY = "nn-gate-unlocked";
  const HASH = "94d52aba88bcbde543bf1b2f01b656901b9eae2ff3a20f4d2ad03407a32d422b";

  const gated = document.getElementById("gate-content");
  const dlg = document.getElementById("gate-modal") as HTMLDialogElement | null;
  const form = document.getElementById("gate-form") as HTMLFormElement | null;
  const input = document.getElementById("gate-password") as HTMLInputElement | null;
  const error = document.getElementById("gate-error");

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let pendingId: string | null = null;

  /*
    localStorage kann blockiert sein (z. B. Privatmodus) und wirft dann beim
    Zugriff — deshalb immer mit try/catch und In-Memory-Fallback für die Sitzung.
  */
  let unlockedInMemory = false;
  const unlocked = () => {
    try {
      if (localStorage.getItem(KEY) === "1") return true;
    } catch {
      /* Speicher nicht verfügbar */
    }
    return unlockedInMemory;
  };
  const persistUnlock = () => {
    unlockedInMemory = true;
    try {
      localStorage.setItem(KEY, "1");
    } catch {
      /* Speicher nicht verfügbar — Freischaltung gilt für diese Sitzung */
    }
  };
  const reveal = () => gated?.removeAttribute("hidden");

  if (unlocked()) reveal();

  const scrollToId = (id: string | null) => {
    const el = id ? document.getElementById(id) : null;
    el?.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" });
  };

  /*
    Klicks auf In-Page-Links in den gesperrten Bereich abfangen (Capture-Phase,
    läuft vor dem Smooth-Scroll-Handler im BaseLayout).
  */
  document.addEventListener(
    "click",
    (e) => {
      if (unlocked() || !gated || !dlg) return;
      const a = (e.target as Element).closest?.('a[href^="#"]');
      if (!a) return;
      const id = (a.getAttribute("href") ?? "").slice(1);
      const target = id ? document.getElementById(id) : null;
      if (!target || !gated.contains(target)) return;
      e.preventDefault();
      e.stopPropagation();

      // Mobiles Menü ggf. schließen, damit der Dialog frei steht
      const menu = document.getElementById("mobile-menu");
      const toggle = document.getElementById("nav-toggle");
      if (menu && !menu.hasAttribute("hidden")) {
        menu.setAttribute("hidden", "");
        toggle?.setAttribute("aria-expanded", "false");
      }

      pendingId = id;
      if (error) error.hidden = true;
      dlg.showModal();
      input?.focus();
    },
    true
  );

  /*
    Reine JS-Implementierung von SHA-256. Bewusst KEIN crypto.subtle: das ist nur
    in sicheren Kontexten (HTTPS/localhost) verfügbar und wäre über http:// nicht
    vorhanden, wodurch die Prüfung immer fehlschlägt. Diese Variante läuft überall.
    Basis: geraintluff/sha256, ergänzt um sauberes UTF-8.
  */
  function utf8Bytes(str: string): string {
    let out = "";
    for (const ch of str) {
      const code = ch.codePointAt(0) as number;
      if (code < 0x80) out += String.fromCharCode(code);
      else if (code < 0x800)
        out += String.fromCharCode(0xc0 | (code >> 6), 0x80 | (code & 0x3f));
      else if (code < 0x10000)
        out += String.fromCharCode(
          0xe0 | (code >> 12),
          0x80 | ((code >> 6) & 0x3f),
          0x80 | (code & 0x3f)
        );
      else
        out += String.fromCharCode(
          0xf0 | (code >> 18),
          0x80 | ((code >> 12) & 0x3f),
          0x80 | ((code >> 6) & 0x3f),
          0x80 | (code & 0x3f)
        );
    }
    return out;
  }

  function sha256Hex(value: string): string {
    const ascii = utf8Bytes(value);
    const rr = (v: number, a: number) => (v >>> a) | (v << (32 - a));
    const maxWord = Math.pow(2, 32);
    let result = "";
    const words: number[] = [];
    const asciiBitLength = ascii.length * 8;

    let hash: number[] = [];
    const k: number[] = [];
    let primeCounter = 0;
    const isComposite: Record<number, number> = {};
    for (let candidate = 2; primeCounter < 64; candidate++) {
      if (!isComposite[candidate]) {
        for (let i = 0; i < 313; i += candidate) isComposite[i] = candidate;
        hash[primeCounter] = (Math.pow(candidate, 0.5) * maxWord) | 0;
        k[primeCounter++] = (Math.pow(candidate, 1 / 3) * maxWord) | 0;
      }
    }

    let padded = ascii + "\x80";
    while (padded.length % 64 !== 56) padded += "\x00";
    for (let i = 0; i < padded.length; i++) {
      words[i >> 2] |= padded.charCodeAt(i) << (((3 - i) % 4) * 8);
    }
    words[words.length] = (asciiBitLength / maxWord) | 0;
    words[words.length] = asciiBitLength;

    for (let j = 0; j < words.length; ) {
      const w = words.slice(j, (j += 16));
      const oldHash = hash;
      hash = hash.slice(0, 8);
      for (let i = 0; i < 64; i++) {
        const w15 = w[i - 15];
        const w2 = w[i - 2];
        const a = hash[0];
        const e = hash[4];
        const temp1 =
          hash[7] +
          (rr(e, 6) ^ rr(e, 11) ^ rr(e, 25)) +
          ((e & hash[5]) ^ (~e & hash[6])) +
          k[i] +
          (w[i] =
            i < 16
              ? w[i]
              : (w[i - 16] +
                  (rr(w15, 7) ^ rr(w15, 18) ^ (w15 >>> 3)) +
                  w[i - 7] +
                  (rr(w2, 17) ^ rr(w2, 19) ^ (w2 >>> 10))) |
                0);
        const temp2 =
          (rr(a, 2) ^ rr(a, 13) ^ rr(a, 22)) +
          ((a & hash[1]) ^ (a & hash[2]) ^ (hash[1] & hash[2]));
        hash = [(temp1 + temp2) | 0].concat(hash);
        hash[4] = (hash[4] + temp1) | 0;
      }
      for (let i = 0; i < 8; i++) hash[i] = (hash[i] + oldHash[i]) | 0;
    }

    for (let i = 0; i < 8; i++) {
      for (let j = 3; j + 1; j--) {
        const b = (hash[i] >> (j * 8)) & 255;
        result += (b < 16 ? "0" : "") + b.toString(16);
      }
    }
    return result;
  }

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!input) return;
    let ok = false;
    try {
      ok = sha256Hex(input.value) === HASH;
    } catch {
      ok = false;
    }
    if (ok) {
      persistUnlock();
      reveal();
      dlg?.close();
      input.value = "";
      scrollToId(pendingId ?? "about");
      pendingId = null;
    } else if (error) {
      error.hidden = false;
      input.select();
    }
  });
</script>
